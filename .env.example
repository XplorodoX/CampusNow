# CampusNow – Beispiel-Konfiguration
# Kopieren nach .env und Werte anpassen:  cp .env.example .env

# --- Datenbank ---
MONGO_URI=mongodb://admin:PASSWORT@mongodb:27017/campusnow?authSource=admin
MONGO_DB=campusnow

# --- API ---
API_KEY=dein-geheimes-passwort
API_TITLE=CampusNow API
API_VERSION=1.0.0
CORS_ORIGINS=*
LOG_LEVEL=INFO

# --- Zeitzone ---
TZ=Europe/Berlin
